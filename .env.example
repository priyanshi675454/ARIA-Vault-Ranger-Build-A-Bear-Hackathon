REBALANCE_INTERVAL_MS=3600000

# ── Strategy Parameters ──────────────────
MIN_APY_THRESHOLD=0.10
TARGET_APY=0.20
MAX_SINGLE_PROTOCOL_ALLOCATION=0.50
