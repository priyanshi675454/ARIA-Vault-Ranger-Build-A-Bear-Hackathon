# ─────────────────────────────────────────
#  ARIA Vault — Environment Configuration
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Solana ──────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
SOLANA_NETWORK=mainnet-beta
WALLET_PRIVATE_KEY=your_base58_private_key_here
VAULT_ADDRESS=your_ranger_vault_address_after_deployment

# ── Helius (free 1 month from hackathon) ──
HELIUS_API_KEY=your_helius_api_key

# ── Ranger Earn ─────────────────────────
RANGER_VAULT_PROGRAM_ID=RngrVRkrK7QFAzGBvkYDEnHECECgD5YrpxrLMtGZfGt

# ── Protocol Addresses (Mainnet) ─────────
KAMINO_MARKET_ADDRESS=7u3HeHxYDLhnCoErrtycNokbQYbWGzLs6JSDqGAv5PfF
MARGINFI_GROUP_ADDRESS=4qp6Fx6tnZkY5Wropq9wUYgtFxXKwE6viZxFHg3rdAG8

# ── AI Engine ────────────────────────────
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_SECRET=your_secret_key_here

# ── Risk Oracle ──────────────────────────
RISK_SCORE_ACCOUNT=your_risk_oracle_account_pubkey
